<ui:FluentWindow x:Class="TinyUa.Explorer.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:conv="clr-namespace:TinyUa.Explorer.Converters"
                 xmlns:vm="clr-namespace:TinyUa.Explorer.ViewModels"
                 Title="TinyUa Explorer"
                 Width="1280" Height="800"
                 MinWidth="900" MinHeight="600"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">

    <ui:FluentWindow.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Custom Title Bar ═══ -->
        <ui:TitleBar Grid.Row="0" Title="TinyUa Explorer">
            <ui:TitleBar.Icon>
                <ui:FontIcon Glyph="&#xE946;" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- ═══ Main Content ═══ -->
        <Grid Grid.Row="1" Margin="8,0,8,8">

            <!-- ── Connection Bar ── -->
            <Grid Height="44" VerticalAlignment="Top" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBlock Grid.Column="0" Text="Endpoint:"
                              VerticalAlignment="Center"
                              Margin="4,0,8,0"
                              FontTypography="Body" />

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding EndpointHistory}"
                          Text="{Binding EndpointUrl, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          KeyDown="EndpointUrl_KeyDown" />

                <ui:Button Grid.Column="2"
                           Icon="{ui:SymbolIcon Shield24}"
                           Content="Security..."
                           Command="{Binding SecurityCommand}"
                           Margin="0,0,4,0"
                           VerticalAlignment="Center"
                           Appearance="Secondary" />

                <ui:TextBlock Grid.Column="3"
                              Text="{Binding SecuritySummary}"
                              VerticalAlignment="Center"
                              Margin="4,0,8,0"
                              TextTrimming="CharacterEllipsis"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              FontTypography="Caption" />

                <ui:Button Grid.Column="4"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon PlugConnected24}"
                           Content="Connect"
                           Command="{Binding ConnectCommand}"
                           Margin="0,0,4,0"
                           VerticalAlignment="Center" />

                <ui:Button Grid.Column="5"
                           Appearance="Caution"
                           Icon="{ui:SymbolIcon PlugDisconnected24}"
                           Content="Disconnect"
                           Command="{Binding DisconnectCommand}"
                           Margin="4,0,4,0"
                           VerticalAlignment="Center" />

                <Ellipse Grid.Column="6"
                         Width="12" Height="12"
                         VerticalAlignment="Center"
                         Margin="8,0,0,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#4CAF50" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                    <Setter Property="Fill" Value="#F44336" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ConnectionStatus}" Value="Reconnecting...">
                                    <Setter Property="Fill" Value="#FF9800" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </Grid>

            <!-- ── Three-Panel Layout ── -->
            <Grid Margin="0,52,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" MinWidth="200" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" MinWidth="300" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="340" MinWidth="200" />
                </Grid.ColumnDefinitions>

                <!-- ═══ Left: Address Space Tree ═══ -->
                <Border Grid.Column="0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="6"
                        Padding="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ui:TextBlock Grid.Row="0" Text="Address Space"
                                      FontTypography="BodyStrong"
                                      Margin="8,4,8,4" />

                        <TreeView Grid.Row="1"
                                  x:Name="AddressSpaceTree"
                                  ItemsSource="{Binding RootNodes}"
                                  SelectedItemChanged="TreeView_SelectedItemChanged"
                                  PreviewMouseLeftButtonDown="TreeView_PreviewMouseLeftButtonDown"
                                  PreviewMouseMove="TreeView_PreviewMouseMove"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="Padding" Value="2,3" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Node class icon (Fluent UI System Icons) -->
                                        <ui:SymbolIcon FontSize="14" Margin="0,0,6,0">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Symbol" Value="Circle24" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NodeClass}" Value="Object">
                                                            <Setter Property="Symbol" Value="Cube24" />
                                                            <Setter Property="Foreground" Value="#FFB74D" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeClass}" Value="Variable">
                                                            <Setter Property="Symbol" Value="Tag24" />
                                                            <Setter Property="Foreground" Value="#4FC3F7" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeClass}" Value="Method">
                                                            <Setter Property="Symbol" Value="Flash24" />
                                                            <Setter Property="Foreground" Value="#81C784" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeClass}" Value="DataType">
                                                            <Setter Property="Symbol" Value="Database24" />
                                                            <Setter Property="Foreground" Value="#CE93D8" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeClass}" Value="ReferenceType">
                                                            <Setter Property="Symbol" Value="ArrowRouting24" />
                                                            <Setter Property="Foreground" Value="#90A4AE" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeClass}" Value="ObjectType">
                                                            <Setter Property="Symbol" Value="CubeSync24" />
                                                            <Setter Property="Foreground" Value="#FFCC80" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeClass}" Value="VariableType">
                                                            <Setter Property="Symbol" Value="Box24" />
                                                            <Setter Property="Foreground" Value="#81D4FA" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeClass}" Value="View">
                                                            <Setter Property="Symbol" Value="Eye24" />
                                                            <Setter Property="Foreground" Value="#A5D6A7" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   ToolTip="{Binding NodeIdText}"
                                                   VerticalAlignment="Center" />
                                        <!-- Loading spinner -->
                                        <ui:ProgressRing IsIndeterminate="True"
                                                         Width="14" Height="14"
                                                         Margin="6,0,0,0"
                                                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              ResizeBehavior="PreviousAndNext" />

                <!-- ═══ Center: Monitored Items (drag-drop target) ═══ -->
                <Border Grid.Column="2"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="6"
                        Padding="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4,8,4">
                            <ui:TextBlock Text="Monitored Items"
                                          FontTypography="BodyStrong"
                                          VerticalAlignment="Center" />
                            <ui:TextBlock Text=" (drag nodes here, right-click for options)"
                                          VerticalAlignment="Center"
                                          FontSize="11"
                                          Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  x:Name="MonitoredItemsGrid"
                                  ItemsSource="{Binding Subscriptions}"
                                  AllowDrop="True"
                                  DragOver="MonitoredItems_DragOver"
                                  Drop="MonitoredItems_Drop"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  PreviewMouseRightButtonDown="MonitoredItemsGrid_PreviewMouseRightButtonDown">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Change Interval..."
                                              Click="ChangeInterval_Click" />
                                    <MenuItem Header="Unsubscribe"
                                              Click="Unsubscribe_Click" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Node" Binding="{Binding DisplayName}" Width="Auto" />
                                <DataGridTextColumn Header="NodeId" Binding="{Binding NodeId}" Width="Auto" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" />
                                <DataGridTextColumn Header="Interval" Binding="{Binding Interval, StringFormat={}{0} ms}" Width="Auto" />
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="3"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              ResizeBehavior="PreviousAndNext" />

                <!-- ═══ Right: Attributes ═══ -->
                <Border Grid.Column="4"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="6"
                        Padding="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header with copy NodeId button -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4,8,4">
                            <ui:TextBlock Text="Attributes"
                                          FontTypography="BodyStrong"
                                          VerticalAlignment="Center" />
                            <ui:TextBlock Text="{Binding SelectedNode.DisplayName, StringFormat=' — {0}'}"
                                          VerticalAlignment="Center"
                                          Margin="4,0,0,0"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          TextTrimming="CharacterEllipsis"
                                          MaxWidth="200" />
                        </StackPanel>

                        <!-- Action buttons -->
                        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="8,0,8,8">
                            <ui:Button Icon="{ui:SymbolIcon ArrowSync24}"
                                       Content="Read"
                                       Command="{Binding ReadValueCommand}"
                                       Margin="0,0,4,0"
                                       Appearance="Secondary" />
                            <ui:Button Icon="{ui:SymbolIcon Copy24}"
                                       Content="Copy NodeId"
                                       Command="{Binding CopyNodeIdCommand}"
                                       Margin="0,0,4,0"
                                       Appearance="Secondary" />
                            <ui:Button Icon="{ui:SymbolIcon ArrowSync24}"
                                       Content="Refresh"
                                       Command="{Binding RefreshNodeCommand}"
                                       Margin="0,0,4,0"
                                       Appearance="Secondary" />
                            <ui:TextBox Text="{Binding WriteValue, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Value to write..."
                                        MinWidth="120"
                                        Margin="4,0,4,0" />
                            <ui:Button Icon="{ui:SymbolIcon Edit24}"
                                       Content="Write"
                                       Command="{Binding WriteValueCommand}"
                                       Margin="0,0,4,0"
                                       Appearance="Caution" />
                            <ui:Button Icon="{ui:SymbolIcon Eye24}"
                                       Content="Subscribe"
                                       Command="{Binding SubscribeCommand}"
                                       Appearance="Primary" />
                        </WrapPanel>

                        <!-- Attributes DataGrid with context menu for copy -->
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding Attributes}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  SelectionMode="Single"
                                  SelectionUnit="Cell">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Copy Value" Click="CopyAttributeValue_Click" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Attribute" Binding="{Binding Attribute}" Width="100" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="60" />
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBlock Grid.Column="0"
                              Text="{Binding StatusText}"
                              VerticalAlignment="Center"
                              TextTrimming="CharacterEllipsis" />

                <ui:TextBlock Grid.Column="1"
                              Text="{Binding ConnectionStatus}"
                              VerticalAlignment="Center"
                              Margin="16,0,0,0">
                    <ui:TextBlock.Style>
                        <Style TargetType="ui:TextBlock">
                            <Setter Property="Foreground" Value="#4CAF50" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                    <Setter Property="Foreground" Value="#F44336" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ConnectionStatus}" Value="Reconnecting...">
                                    <Setter Property="Foreground" Value="#FF9800" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:TextBlock.Style>
                </ui:TextBlock>

                <ui:TextBlock Grid.Column="2"
                              Text="{Binding SessionInfo}"
                              VerticalAlignment="Center"
                              Margin="16,0,0,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
